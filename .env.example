# ── Free Providers (required for free tier to work) ──────────────
OPENROUTER_API_KEY=       # Get from: https://openrouter.ai/keys (free, no CC)
GEMINI_API_KEY=           # Get from: https://aistudio.google.com/apikey (free, no CC)
GROQ_API_KEY=             # Get from: https://console.groq.com/keys (free, no CC)
MISTRAL_API_KEY=          # Get from: https://console.mistral.ai/api-keys (free, phone verification)

# ── Supabase ──────────────────────────────────────────────────────
PUBLIC_SUPABASE_URL=             # https://<project>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=        # Publishable/anon key from Supabase dashboard
SUPABASE_SERVICE_ROLE_KEY=       # Secret/service_role key (server-side only)

# ── Benchmarks (optional) ─────────────────────────────────────────
ARTIFICIAL_ANALYSIS_API_KEY=     # https://artificialanalysis.ai/documentation (free, 1k req/day). Without it, model detail pages show "Benchmark data not available".

# ── Web search (optional) ─────────────────────────────────────────
TAVILY_API_KEY=                  # https://app.tavily.com/ (free, 1k searches/month). Powers the chat composer's Search toggle. Without it, the toggle is a no-op and the model answers without web context.

# ── Dev Settings ──────────────────────────────────────────────────
BYPASS_RATE_LIMIT=false          # Set to "true" to skip internal rate limiting in dev

# ── Paid Providers (not needed yet — stubs return 403) ───────────
# ANTHROPIC_API_KEY=      # https://console.anthropic.com/
# OPENAI_API_KEY=         # https://platform.openai.com/api-keys
# XAI_API_KEY=            # https://console.x.ai/
# DEEPSEEK_API_KEY=       # https://platform.deepseek.com/
# MOONSHOT_API_KEY=       # https://platform.moonshot.ai/
# COHERE_API_KEY=         # https://dashboard.cohere.com/api-keys
# PERPLEXITY_API_KEY=     # https://www.perplexity.ai/settings/api
# QWEN_API_KEY=           # https://dashscope.console.aliyun.com/
